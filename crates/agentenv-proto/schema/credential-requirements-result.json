{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CredentialRequirementsResult",
  "type": "object",
  "properties": {
    "requirements": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/CredentialRequirement"
      }
    }
  },
  "definitions": {
    "CredentialKind": {
      "type": "string",
      "enum": [
        "api_key",
        "token",
        "certificate",
        "file"
      ]
    },
    "CredentialRequirement": {
      "type": "object",
      "required": [
        "name",
        "required"
      ],
      "properties": {
        "description": {
          "default": "",
          "type": "string"
        },
        "kind": {
          "default": "api_key",
          "allOf": [
            {
              "$ref": "#/definitions/CredentialKind"
            }
          ]
        },
        "name": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "validator": {
          "anyOf": [
            {
              "$ref": "#/definitions/ValidatorSpec"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "ValidatorSpec": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind",
            "pattern"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "regex"
              ]
            },
            "pattern": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "url"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "curl_probe"
              ]
            },
            "url": {
              "type": "string"
            }
          }
        }
      ]
    }
  }
}
