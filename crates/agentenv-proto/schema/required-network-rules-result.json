{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RequiredNetworkRulesResult",
  "type": "object",
  "properties": {
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/NetworkRule"
      }
    }
  },
  "definitions": {
    "NetworkRule": {
      "type": "object",
      "required": [
