          "type": "string"
        },
        "port": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint16",
          "minimum": 0.0
        },
        "scheme": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
