{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ListSessionsResult",
  "type": "object",
  "properties": {
    "sessions": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/SessionHandle"
      }
    }
  },
  "definitions": {
    "SessionHandle": {
      "type": "object",
      "required": [
        "command",
        "created_at",
        "name",
        "session_id",
        "status",
        "updated_at"
      ],
      "properties": {
        "command": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/SessionStatus"
        },
        "updated_at": {
          "type": "string"
        },
        "working_dir": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "SessionStatus": {
      "type": "string",
      "enum": [
        "starting",
        "attached",
        "detached",
        "exited",
        "killed",
        "unknown"
      ]
    }
  }
}
