{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SandboxStatus",
  "type": "object",
  "required": [
    "healthy",
    "phase"
  ],
  "properties": {
    "healthy": {
      "type": "boolean"
    },
    "last_ping": {
      "type": [
        "string",
        "null"
      ]
    },
    "phase": {
      "$ref": "#/definitions/SandboxPhase"
    }
  },
  "definitions": {
    "SandboxPhase": {
      "type": "string",
      "enum": [
        "creating",
        "running",
        "stopped",
        "destroyed",
        "error"
      ]
    }
  }
}
