{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ApplyPolicyParams",
  "type": "object",
  "required": [
    "handle",
    "policy"
  ],
  "properties": {
    "handle": {
      "type": "string"
    },
    "policy": {
      "$ref": "#/definitions/NetworkPolicy"
    }
  },
  "definitions": {
    "NetworkPolicy": {
      "type": "object",
      "properties": {
        "allow": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/NetworkRule"
          }
        },
        "approval": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/NetworkRule"
          }
        },
        "deny": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/NetworkRule"
          }
        }
      }
    },
    "NetworkRule": {
      "type": "object",
      "required": [
        "host"
      ],
      "properties": {
        "host": {
          "type": "string"
        },
        "port": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint16",
          "minimum": 0.0
        },
        "scheme": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
